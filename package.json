{
  "name": "monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@8.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter web --workspace-root run dev",
    "dev:admin": "pnpm --filter admin --workspace-root run dev",
    "dev:all": "pnpm run dev:web & pnpm run dev:admin",
    "build:web": "pnpm --filter web --workspace-root run build",
    "build:admin": "pnpm --filter admin --workspace-root run build",
    "build:all": "pnpm run build:web && pnpm run build:admin"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "next-auth": "^4.24.13",
    "pg-adapter": "^1.3.6",
    "prisma": "^6.15.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "^3.0.0",
    "typescript": "^5.0.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "schema": "packages/shared/prisma/schema.prisma"
  },
  "devDependencies": {
    "@prisma/internals": "^7.5.0",
    "@types/node": "25.5.0"
  }
}
